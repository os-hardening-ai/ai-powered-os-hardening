[run]
branch = False
source = llm
omit =
    */tests/*
    llm/tests/*
    llm/cli/*
    llm/examples/*
    llm/ml/evaluation/*
    */__pycache__/*

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
    if TYPE_CHECKING:
    \.\.\.
show_missing = True
precision = 1

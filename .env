GROQ_API_KEY="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"

# ===================================
# LLM Provider Configuration
# ===================================
# Choose one: groq (FREE), ollama (FREE Local), huggingface, openai (PAID),novita (PAID)
# RECOMMENDED FOR DEMO: groq (completely free, fast)
LLM_PROVIDER=groq

# ===================================
# Groq API Configuration (🎁 100% FREE - RECOMMENDED)
# ===================================
# Get FREE API key from: https://console.groq.com/keys
# Free tier: 30 req/min, 14400 req/day
# Speed: 500+ tokens/sec (fastest LLM API)
# Cost: $0 (completely free)
GROQ_SMALL_MODEL_NAME=llama-3.1-8b-instant
GROQ_LARGE_MODEL_NAME=llama-3.3-70b-versatile

# ===================================
# Novita LLM Configuration
# ===================================
# LLM_PROVIDER=novita olarak ayarlandığında kullanılır
# Model adları: https://novita.ai/llm-api
NOVITA_SMALL_MODEL_NAME=meta-llama/llama-3.1-8b-instruct
NOVITA_LARGE_MODEL_NAME=deepseek/deepseek-v3-0324

# ===================================
# Model Sampling Parameters
# ===================================
# Temperature: 0.0 (deterministic) to 2.0 (creative)
# Small model: Used for classification tasks (lower temp)
# Large model: Used for answer generation (moderate temp)
SMALL_MODEL_TEMPERATURE=0.3
LARGE_MODEL_TEMPERATURE=0.2

# Max tokens per response
MAX_TOKENS=8192

# ===================================
# Pipeline Behavior
# ===================================
# Enable detailed debug logs (true/false)
ENABLE_DEBUG_LOGS=true

# Enable output quality checking (true/false)
ENABLE_JUDGE_STEP=false

# Enable answer correction if judge detects issues (true/false)
ENABLE_CORRECTION_STEP=false

# ===================================
# Advanced Settings (Optional)
# ===================================
# API request timeout in seconds
# REQUEST_TIMEOUT=60

# Number of retry attempts on API failures
# MAX_RETRIES=2

# ===================================
# OpenTelemetry / Jaeger Tracing
# ===================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4317
OTEL_SERVICE_NAME=hardening-api

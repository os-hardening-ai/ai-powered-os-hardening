# =============================================================================
# hardening-monitoring — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# Backend URL (where the AI-Powered OS Hardening backend is running)
BACKEND_URL=http://localhost:8000

# OpenTelemetry Collector endpoint (for backend to send traces/metrics)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=hardening-backend
OTEL_SERVICE_VERSION=1.0.0

# Grafana admin credentials
GRAFANA_ADMIN_PASSWORD=hardening123

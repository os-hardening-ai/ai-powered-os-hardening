{
  "info": {
    "name": "AI-Powered OS Hardening API",
    "description": "Newman API smoke/contract suite. Offline-capable endpoints (health, metrics, rules, artifacts, agents) must always pass; LLM/RAG endpoints (chat, rag, v1) require Groq/Qdrant/Novita reachability.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8011" }
  ],
  "item": [
    {
      "name": "Health: GET /health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "pm.test('has status field', () => pm.expect(pm.response.json()).to.have.property('status'));"
      ] } }]
    },
    {
      "name": "Monitoring: GET /metrics/prometheus",
      "request": { "method": "GET", "url": "{{baseUrl}}/metrics/prometheus" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "pm.test('exposes prometheus metrics', () => pm.expect(pm.response.text()).to.include('hardening_'));"
      ] } }]
    },
    {
      "name": "OpenAI-compat: GET /v1/models",
      "request": { "method": "GET", "url": "{{baseUrl}}/v1/models" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "pm.test('has data array', () => pm.expect(pm.response.json()).to.have.property('data'));"
      ] } }]
    },
    {
      "name": "Domain: GET /api/rules?limit=5",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/rules?limit=5" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "const j = pm.response.json();",
        "pm.test('returns rules', () => pm.expect(j.rules.length).to.be.above(0));",
        "pm.test('total present', () => pm.expect(j).to.have.property('total'));"
      ] } }]
    },
    {
      "name": "Domain: POST /api/rules/plan",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/rules/plan",
        "body": { "mode": "raw", "raw": "{\"rule_ids\": [\"1.1.1.1\", \"1.1.1.2\", \"1.1.1.3\"]}" }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "const j = pm.response.json();",
        "pm.test('ordered_rules returned', () => pm.expect(j.ordered_rules.length).to.eql(3));",
        "pm.test('has conflicts array', () => pm.expect(j).to.have.property('conflicts'));"
      ] } }]
    },
    {
      "name": "Domain: POST /api/artifacts/generate (bash)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/artifacts/generate",
        "body": { "mode": "raw", "raw": "{\"rule_ids\": [\"1.1.1.1\", \"1.1.1.2\"], \"format\": \"bash\", \"os_target\": \"ubuntu_24_04\", \"security_level\": \"balanced\"}" }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "const j = pm.response.json();",
        "pm.test('bash format', () => pm.expect(j.format).to.eql('bash'));",
        "pm.test('non-empty content', () => pm.expect(j.content.length).to.be.above(0));"
      ] } }]
    },
    {
      "name": "Agent İP-6: POST /api/agent/plan",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/agent/plan",
        "body": { "mode": "raw", "raw": "{\"goal\": \"SSH ve parola politikasini sikilastir\", \"os_target\": \"ubuntu_24_04\", \"security_level\": \"balanced\"}" }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "const j = pm.response.json();",
        "pm.test('plan has items', () => pm.expect(j.items.length).to.be.above(0));",
        "pm.test('items ordered', () => { const o = j.items.map(i=>i.order); pm.expect(o).to.eql(o.slice().sort((a,b)=>a-b)); });"
      ] } }]
    },
    {
      "name": "Agent İP-6: empty goal -> 422",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/agent/plan",
        "body": { "mode": "raw", "raw": "{\"goal\": \"\"}" }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('422 validation error', () => pm.response.to.have.status(422));"
      ] } }]
    },
    {
      "name": "Agent İP-7: POST /api/agent/harden (bash)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/agent/harden",
        "body": { "mode": "raw", "raw": "{\"goal\": \"SSH sikilastir\", \"os_target\": \"ubuntu_24_04\", \"security_level\": \"balanced\", \"format\": \"bash\"}" }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "const j = pm.response.json();",
        "pm.test('multi-step trace present', () => { const n = j.steps.map(s=>s.name); pm.expect(n).to.include('plan'); pm.expect(n).to.include('generate'); pm.expect(n).to.include('verify'); });",
        "pm.test('artifact generated', () => pm.expect(j.artifact_content.length).to.be.above(0));"
      ] } }]
    },
    {
      "name": "RAG: POST /rag/search (needs Qdrant)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/rag/search",
        "body": { "mode": "raw", "raw": "{\"query\": \"SSH PermitRootLogin hardening\", \"top_k\": 3}" }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "pm.test('has results array', () => pm.expect(pm.response.json()).to.have.property('results'));"
      ] } }]
    },
    {
      "name": "Chat: POST /api/chat (needs Groq)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/chat",
        "body": { "mode": "raw", "raw": "{\"question\": \"Ubuntu 24.04 sunucumda SSH'i nasil sikilastiririm?\", \"use_rag\": false, \"timeout\": 60}" }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "pm.test('has answer', () => pm.expect(pm.response.json()).to.have.property('answer'));"
      ] } }]
    },
    {
      "name": "OpenAI-compat: POST /v1/chat/completions (needs Groq)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/v1/chat/completions",
        "body": { "mode": "raw", "raw": "{\"model\": \"hardening-ai\", \"messages\": [{\"role\": \"user\", \"content\": \"What is SSH hardening?\"}]}" }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "pm.test('openai choices shape', () => pm.expect(pm.response.json()).to.have.property('choices'));"
      ] } }]
    }
  ]
}

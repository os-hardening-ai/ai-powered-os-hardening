# .env

# LLM Provider seçimi: "groq" | "openai" | "huggingface"
LLM_PROVIDER="groq"

# Groq API (Önerilen: En ucuz ve en hızlı)
GROQ_API_KEY=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

# ✅ GÜNCEL Groq modelleri (Aralık 2024)
GROQ_SMALL_MODEL_NAME=llama-3.1-8b-instant
GROQ_LARGE_MODEL_NAME=llama-3.3-70b-versatile

# Sampling parametreleri
SMALL_MODEL_TEMPERATURE=0.3
LARGE_MODEL_TEMPERATURE=0.2
MAX_TOKENS=256

# Debug
ENABLE_DEBUG_LOGS=true
ENABLE_JUDGE_STEP=false
ENABLE_CORRECTION_STEP=false
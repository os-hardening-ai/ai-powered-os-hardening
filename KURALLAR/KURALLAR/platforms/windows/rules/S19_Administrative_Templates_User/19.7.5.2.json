{
    "rule_id": "19.7.5.2",
    "title": "Ensure 'Notify antivirus programs when opening attachments' is set to 'Enabled'",
    "description": "Automated configuration for 19.7.5.2",
    "cis_level": 1,
    "category": "Administrative Templates: Windows Components",
    "applies_to": [
        "Windows 11",
        "Windows 10",
        "Windows Server 2022"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKCU:\\\\Software\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Policies\\\\Attachments",
        "value_name": "ScanWithAntiVirus",
        "value_type": "REG_DWORD",
        "value_data": 3,
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\...",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "System"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Attachments')) { New-Item -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Attachments' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Attachments' -Name 'ScanWithAntiVirus' -Value 3 -Type DWORD -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Attachments\\ScanWithAntiVirus",
        "inf_value": "4,1",
        "gpo_xml": "<RegistryValue name='ScanWithAntiVirus' type='REG_DWORD' value='3'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Attachments' -Name 'ScanWithAntiVirus' -ErrorAction SilentlyContinue).'ScanWithAntiVirus'; return ($val -eq 3)",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Attachments' -Name 'ScanWithAntiVirus' -Force"
    },
    "tags": [
        "admin-templates",
        "cis",
        "registry",
        "automated"
    ]
}
{
    "rule_id": "19.6.6.1.1",
    "title": "Ensure 'Turn off Help Experience Improvement Program' is set to 'Enabled'",
    "description": "Automated configuration for 19.6.6.1.1",
    "cis_level": 2,
    "category": "Administrative Templates: System",
    "applies_to": [
        "Windows 11",
        "Windows 10",
        "Windows Server 2022"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKCU:\\\\Software\\\\Policies\\\\Microsoft\\\\Assistance\\\\Client\\\\1.0",
        "value_name": "NoImplicitFeedback",
        "value_type": "REG_DWORD",
        "value_data": 1,
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\...",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "System"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKCU:\\Software\\Policies\\Microsoft\\Assistance\\Client\\1.0')) { New-Item -Path 'HKCU:\\Software\\Policies\\Microsoft\\Assistance\\Client\\1.0' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKCU:\\Software\\Policies\\Microsoft\\Assistance\\Client\\1.0' -Name 'NoImplicitFeedback' -Value 1 -Type DWORD -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\HKCU:\\Software\\Policies\\Microsoft\\Assistance\\Client\\1.0\\NoImplicitFeedback",
        "inf_value": "4,1",
        "gpo_xml": "<RegistryValue name='NoImplicitFeedback' type='REG_DWORD' value='1'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKCU:\\Software\\Policies\\Microsoft\\Assistance\\Client\\1.0' -Name 'NoImplicitFeedback' -ErrorAction SilentlyContinue).'NoImplicitFeedback'; return ($val -eq 1)",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKCU:\\Software\\Policies\\Microsoft\\Assistance\\Client\\1.0' -Name 'NoImplicitFeedback' -Force"
    },
    "tags": [
        "admin-templates",
        "cis",
        "registry",
        "automated"
    ]
}
        "inf_key": "MACHINE\\HKLM:\\Software\\Policies\\Microsoft\\FVE\\OSAllowedHardwareEncryptionAlgorithms",
        "inf_value": "4,1",
        "gpo_xml": "<RegistryValue name='OSAllowedHardwareEncryptionAlgorithms' type='REG_SZ' value='2.16.840.1.101.3.4.1.2;2.16.840.1.101.3.4.1.42'/>"
    },
    "audit_logic": {

        "powershell_script": "if (-not (Test-Path 'HKLM:\\Software\\Policies\\Microsoft\\FVE')) { New-Item -Path 'HKLM:\\Software\\Policies\\Microsoft\\FVE' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\Software\\Policies\\Microsoft\\FVE' -Name 'OSAllowedHardwareEncryptionAlgorithms' -Value 2.16.840.1.101.3.4.1.2;2.16.840.1.101.3.4.1.42 -Type SZ -Force",

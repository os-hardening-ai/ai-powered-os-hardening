{
    "rule_id": "18.10.10.2.8",
    "title": "Ensure 'Configure use of hardware-based encryption for operating system drives' is set to 'Disabled'",
    "description": "CIS automated configuration mapping for 18.10.10.2.8",
    "cis_level": "BL",
    "category": "Administrative Templates: Windows Components",
    "applies_to": [
        "Windows 11"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\Software\\\\Policies\\\\Microsoft\\\\FVE",
        "value_name": "OSAllowedHardwareEncryptionAlgorithms",
        "value_type": "REG_SZ",
        "value_data": "2.16.840.1.101.3.4.1.2;2.16.840.1.101.3.4.1.42",

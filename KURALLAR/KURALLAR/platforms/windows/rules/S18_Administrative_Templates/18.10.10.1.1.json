    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\FVE')) { New-Item -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\FVE' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\FVE' -Name 'FDVDiscoveryVolumeType' -Value <none> -Type SZ -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\HKLM:\\SOFTWARE\\Policies\\Microsoft\\FVE\\FDVDiscoveryVolumeType",
        "inf_value": "4,1",
        "gpo_xml": "<RegistryValue name='FDVDiscoveryVolumeType' type='REG_SZ' value='<none>'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\FVE' -Name 'FDVDiscoveryVolumeType' -ErrorAction SilentlyContinue).'FDVDiscoveryVolumeType'; return ($val -eq <none>)",
        "expected_result": true
    },
    "remediation_rollback": {

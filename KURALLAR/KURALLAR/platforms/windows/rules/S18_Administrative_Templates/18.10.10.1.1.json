{
    "rule_id": "18.10.10.1.1",
    "title": "Ensure 'Allow access to BitLocker-protected fixed data drives from earlier versions of Windows' is set to 'Disabled'",
    "description": "CIS automated configuration mapping for 18.10.10.1.1",
    "cis_level": "BL",
    "category": "Administrative Templates: Windows Components",
    "applies_to": [

        "value_name": "FDVDiscoveryVolumeType",
        "value_type": "REG_SZ",
        "value_data": "<none>",
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\...",
        "setting_name": "",

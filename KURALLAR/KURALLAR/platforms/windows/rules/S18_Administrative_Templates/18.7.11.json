{
    "rule_id": "18.7.11",
    "title": "Ensure 'Manage processing of Queue-specific files' is set to 'Enabled: Limit Queue-specific files to Color profiles'",
    "description": "This policy setting configures an Administrative Template related to Printers or Start Menu and Taskbar.",
    "cis_level": 1,
    "category": "Administrative Templates (Printers, Start Menu)",
    "applies_to": [
        "Windows 11",
        "Windows 10",
        "Windows Server 2022",
        "Windows Server 2019"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SOFTWARE\\\\Policies\\\\Microsoft\\\\Windows NT\\\\Printers",
        "value_name": "QueueSpecificFiles",
        "value_type": "REG_DWORD",
        "value_data": 1,
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "AdministrativeTemplates"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows NT\\Printers')) { New-Item -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows NT\\Printers' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows NT\\Printers' -Name 'QueueSpecificFiles' -Value 1 -Type DWord -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\SOFTWARE\\Policies\\Microsoft\\Windows NT\\Printers\\QueueSpecificFiles",
        "inf_value": "4,1",
        "gpo_xml": "<RegistryValue name='QueueSpecificFiles' type='REG_DWORD' value='1'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows NT\\Printers' -Name 'QueueSpecificFiles' -ErrorAction SilentlyContinue).'QueueSpecificFiles'; return ($val -eq 1)",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows NT\\Printers' -Name 'QueueSpecificFiles' -Force"
    },
    "impact": {
        "severity": "medium",
        "description": "Changing template settings can restrict component usage. Test before deploying."
    },
    "rationale": "Enforcing these configurations aligns with CIS benchmark recommendations.",
    "default_value": {
        "standalone": "Not Configured",
        "domain_joined": "Not Configured"
    },
    "references": [
        "https://www.cisecurity.org/benchmark/microsoft_windows_desktop/"
    ],
    "tags": [
        "admin-templates",
        "cis",
        "registry",
        "level-1"
    ]
}
{
    "rule_id": "18.10.56.1",
    "title": "Ensure 'Turn off Push To Install service' is set to 'Enabled'",
    "description": "CIS automated configuration mapping for 18.10.56.1",
    "cis_level": "2",
    "category": "Administrative Templates: Windows Components",
    "applies_to": [
        "Windows 11"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SOFTWARE\\\\Policies\\\\Microsoft\\\\PushToInstall",
        "value_name": "DisablePushToInstall",
        "value_type": "REG_DWORD",
        "value_data": 1,
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\...",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "System"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\PushToInstall')) { New-Item -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\PushToInstall' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\PushToInstall' -Name 'DisablePushToInstall' -Value 1 -Type DWORD -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\HKLM:\\SOFTWARE\\Policies\\Microsoft\\PushToInstall\\DisablePushToInstall",
        "inf_value": "4,1",
        "gpo_xml": "<RegistryValue name='DisablePushToInstall' type='REG_DWORD' value='1'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\PushToInstall' -Name 'DisablePushToInstall' -ErrorAction SilentlyContinue).'DisablePushToInstall'; return ($val -eq 1)",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\PushToInstall' -Name 'DisablePushToInstall' -Force"
    },
    "tags": [
        "admin-templates",
        "cis",

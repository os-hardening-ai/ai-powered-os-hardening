{
    "rule_id": "18.5.13",
    "title": "Ensure 'MSS: (WarningLevel) Percentage threshold for the security event log' is set to 'Enabled: 90% or less'",
    "description": "This policy setting configures an Administrative Template or MSS Legacy registry key.",
    "cis_level": 1,
    "category": "Administrative Templates",
    "applies_to": [
        "Windows 11",
        "Windows 10",
        "Windows Server 2022",
        "Windows Server 2019",
        "Windows Server 2016"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SYSTEM\\\\CurrentControlSet\\\\Services\\\\Eventlog\\\\Security",
        "value_name": "WarningLevel",
        "value_type": "REG_DWORD",
        "value_data": 90,
        "comparison": "less_than_or_equal"
    },
    "gpo_config": {
        "policy_path": "",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "AdministrativeTemplates"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\Eventlog\\Security')) { New-Item -Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\Eventlog\\Security' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\Eventlog\\Security' -Name 'WarningLevel' -Value 90 -Type DWord -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\SYSTEM\\CurrentControlSet\\Services\\Eventlog\\Security\\WarningLevel",
        "inf_value": "4,90",
        "gpo_xml": "<RegistryValue name='WarningLevel' type='REG_DWORD' value='90'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\Eventlog\\Security' -Name 'WarningLevel' -ErrorAction SilentlyContinue).'WarningLevel'; return ($val -le 90)",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\Eventlog\\Security' -Name 'WarningLevel' -Force"
    },
    "impact": {
        "severity": "medium",
        "description": "Changing template settings can restrict component usage or legacy features. Test before deploying."
    },
    "rationale": "Enforcing these settings restricts potential vector surfaces outlined by the CIS benchmark.",
    "default_value": {
        "standalone": "Not Configured",
        "domain_joined": "Not Configured"
    },
    "references": [
        "https://www.cisecurity.org/benchmark/microsoft_windows_desktop/"
    ],
    "tags": [
        "admin-templates",
        "cis",
        "registry",
        "level-1"
    ]
}
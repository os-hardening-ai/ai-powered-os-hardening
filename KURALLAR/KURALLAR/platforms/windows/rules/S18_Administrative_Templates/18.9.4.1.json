{
    "rule_id": "18.9.4.1",
    "title": "Ensure 'Encryption Oracle Remediation' is set to 'Enabled: Force Updated Clients'",
    "description": "This policy setting configures an Administrative Template under the System section.",
    "cis_level": 1,
    "category": "Administrative Templates (System)",
    "applies_to": [
        "Windows 11",
        "Windows 10",
        "Windows Server 2022",
        "Windows Server 2019"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Policies\\\\System\\\\CredSSP\\\\Parameters",
        "value_name": "AllowEncryptionOracle",
        "value_type": "REG_DWORD",
        "value_data": 0,
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\System",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "System"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\CredSSP\\Parameters')) { New-Item -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\CredSSP\\Parameters' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\CredSSP\\Parameters' -Name 'AllowEncryptionOracle' -Value 0 -Type DWord -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\CredSSP\\Parameters\\AllowEncryptionOracle",
        "inf_value": "4,0",
        "gpo_xml": "<RegistryValue name='AllowEncryptionOracle' type='REG_DWORD' value='0'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\CredSSP\\Parameters' -Name 'AllowEncryptionOracle' -ErrorAction SilentlyContinue).'AllowEncryptionOracle'; return ($val -eq 0)",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\CredSSP\\Parameters' -Name 'AllowEncryptionOracle' -Force"
    },
    "impact": {
        "severity": "medium",
        "description": "Changing system template settings can restrict component usage. Test before deploying."
    },
    "rationale": "Enforcing these configurations aligns with CIS benchmark recommendations.",
    "default_value": {
        "standalone": "Not Configured",
        "domain_joined": "Not Configured"
    },
    "references": [
        "https://www.cisecurity.org/benchmark/microsoft_windows_desktop/"
    ],
    "tags": [
        "admin-templates",
        "cis",
        "registry",
        "system",
        "level-1"
    ]
}
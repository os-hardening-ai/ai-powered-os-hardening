{
    "rule_id": "18.10.78.1",
    "title": "Ensure 'Enables or disables Windows Game Recording and Broadcasting' is set to 'Disabled'",
    "description": "Automated configuration for 18.10.78.1",
    "cis_level": 1,
    "category": "Administrative Templates: Windows Components",
    "applies_to": [
        "Windows 11",
        "Windows 10",
        "Windows Server 2022"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SOFTWARE\\\\Microsoft\\\\Policies\\\\PassportForWork\\\\Biometrics",
        "value_name": "EnableESSwithSupportedPeripherals",
        "value_type": "REG_DWORD",
        "value_data": 1,
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\...",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "System"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\\\SOFTWARE\\Microsoft\\Policies\\PassportForWork\\Biometrics')) { New-Item -Path 'HKLM:\\\\SOFTWARE\\Microsoft\\Policies\\PassportForWork\\Biometrics' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\\\SOFTWARE\\Microsoft\\Policies\\PassportForWork\\Biometrics' -Name 'EnableESSwithSupportedPeripherals' -Value 1 -Type DWORD -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\HKLM:\\\\SOFTWARE\\Microsoft\\Policies\\PassportForWork\\Biometrics\\EnableESSwithSupportedPeripherals",
        "inf_value": "4,1",
        "gpo_xml": "<RegistryValue name='EnableESSwithSupportedPeripherals' type='REG_DWORD' value='1'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKLM:\\\\SOFTWARE\\Microsoft\\Policies\\PassportForWork\\Biometrics' -Name 'EnableESSwithSupportedPeripherals' -ErrorAction SilentlyContinue).'EnableESSwithSupportedPeripherals'; return ($val -eq 1)",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKLM:\\\\SOFTWARE\\Microsoft\\Policies\\PassportForWork\\Biometrics' -Name 'EnableESSwithSupportedPeripherals' -Force"
    },
    "tags": [

{
    "rule_id": "18.9.24.1",
    "title": "Ensure 'Enumeration policy for external devices incompatible with Kernel DMA Protection' is set to 'Enabled: Block All'",
    "description": "Automated configuration for 18.9.24.1",
    "cis_level": "BL",
    "category": "Administrative Templates: System",
    "applies_to": [
        "Windows 11",
        "Windows 10",
        "Windows Server 2022"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SOFTWARE\\\\Policies\\\\Microsoft\\\\Windows\\\\Kernel DMA Protection",
        "value_name": "DeviceEnumerationPolicy",
        "value_type": "REG_DWORD",
        "value_data": 0,
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\...",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "System"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\Kernel DMA Protection')) { New-Item -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\Kernel DMA Protection' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\Kernel DMA Protection' -Name 'DeviceEnumerationPolicy' -Value 0 -Type DWORD -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\Kernel DMA Protection\\DeviceEnumerationPolicy",
        "inf_value": "4,1",
        "gpo_xml": "<RegistryValue name='DeviceEnumerationPolicy' type='REG_DWORD' value='0'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\Kernel DMA Protection' -Name 'DeviceEnumerationPolicy' -ErrorAction SilentlyContinue).'DeviceEnumerationPolicy'; return ($val -eq 0)",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\Kernel DMA Protection' -Name 'DeviceEnumerationPolicy' -Force"
    },
    "tags": [
        "admin-templates",
        "cis",
        "registry",
        "automated"
    ]
}
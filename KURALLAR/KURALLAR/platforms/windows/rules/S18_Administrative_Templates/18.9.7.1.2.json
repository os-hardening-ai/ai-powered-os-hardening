{
    "rule_id": "18.9.7.1.2",
    "title": "Ensure 'Prevent installation of devices using drivers for these device setup' is set to 'IEEE 1394 device setup classes'",
    "description": "This policy setting configures an Administrative Template under the System section.",
    "cis_level": 1,
    "category": "Administrative Templates (System)",
    "applies_to": [
        "Windows 11",
        "Windows 10",
        "Windows Server 2022",
        "Windows Server 2019"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SOFTWARE\\\\Policies\\\\Microsoft\\\\Windows\\\\DeviceInstall\\\\Restrictions\\\\DenyDeviceClasses",
        "value_name": "1",
        "value_type": "REG_SZ",
        "value_data": "{6bdd1fc1-810f-11d0-bec7-08002be2092f}",
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\System",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "System"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeviceInstall\\Restrictions\\DenyDeviceClasses')) { New-Item -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeviceInstall\\Restrictions\\DenyDeviceClasses' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeviceInstall\\Restrictions\\DenyDeviceClasses' -Name '1' -Value '{6bdd1fc1-810f-11d0-bec7-08002be2092f}' -Type String -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeviceInstall\\Restrictions\\DenyDeviceClasses\\1",
        "inf_value": "1,{6bdd1fc1-810f-11d0-bec7-08002be2092f}",
        "gpo_xml": "<RegistryValue name='1' type='REG_SZ' value='{6bdd1fc1-810f-11d0-bec7-08002be2092f}'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeviceInstall\\Restrictions\\DenyDeviceClasses' -Name '1' -ErrorAction SilentlyContinue).'1'; return ($val -eq '{6bdd1fc1-810f-11d0-bec7-08002be2092f}')",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeviceInstall\\Restrictions\\DenyDeviceClasses' -Name '1' -Force"
    },
    "impact": {

{
    "rule_id": "18.10.44.1",
    "title": "Ensure 'Allow auditing events in Microsoft Defender Application Guard' is set to 'Enabled'",
    "description": "CIS automated configuration mapping for 18.10.44.1",
    "cis_level": "1",
    "category": "Microsoft Defender Application Guard",
    "applies_to": [
        "Windows 11"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SOFTWARE\\\\Policies\\\\Microsoft\\\\AppHVSI",
        "value_name": "AuditApplicationGuard",
        "value_type": "REG_DWORD",
        "value_data": 1,
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\...",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "System"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\AppHVSI')) { New-Item -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\AppHVSI' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\AppHVSI' -Name 'AuditApplicationGuard' -Value 1 -Type DWORD -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\HKLM:\\SOFTWARE\\Policies\\Microsoft\\AppHVSI\\AuditApplicationGuard",
        "inf_value": "4,1",
        "gpo_xml": "<RegistryValue name='AuditApplicationGuard' type='REG_DWORD' value='1'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\AppHVSI' -Name 'AuditApplicationGuard' -ErrorAction SilentlyContinue).'AuditApplicationGuard'; return ($val -eq 1)",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\AppHVSI' -Name 'AuditApplicationGuard' -Force"
    },
    "tags": [
        "admin-templates",
        "cis",
        "registry",
        "automated"
    ]
}
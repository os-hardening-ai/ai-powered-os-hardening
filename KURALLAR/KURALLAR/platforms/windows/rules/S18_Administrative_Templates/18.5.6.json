{
    "rule_id": "18.5.6",
    "title": "Ensure 'MSS: (KeepAliveTime) How often keep-alive packets are sent' is set to 'Enabled: 300,000'",
    "description": "This policy setting configures an Administrative Template or MSS Legacy registry key.",
    "cis_level": 2,
    "category": "Administrative Templates",
    "applies_to": [
        "Windows 11",
        "Windows 10",
        "Windows Server 2022",
        "Windows Server 2019",
        "Windows Server 2016"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SYSTEM\\\\CurrentControlSet\\\\Services\\\\Tcpip\\\\Parameters",
        "value_name": "KeepAliveTime",
        "value_type": "REG_DWORD",
        "value_data": 300000,
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "AdministrativeTemplates"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters')) { New-Item -Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters' -Name 'KeepAliveTime' -Value 300000 -Type DWord -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters\\KeepAliveTime",
        "inf_value": "4,300000",
        "gpo_xml": "<RegistryValue name='KeepAliveTime' type='REG_DWORD' value='300000'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters' -Name 'KeepAliveTime' -ErrorAction SilentlyContinue).'KeepAliveTime'; return ($val -eq 300000)",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters' -Name 'KeepAliveTime' -Force"
    },
    "impact": {
        "severity": "medium",
        "description": "Changing template settings can restrict component usage or legacy features. Test before deploying."
    },
    "rationale": "Enforcing these settings restricts potential vector surfaces outlined by the CIS benchmark.",
    "default_value": {
        "standalone": "Not Configured",
        "domain_joined": "Not Configured"
    },
    "references": [
        "https://www.cisecurity.org/benchmark/microsoft_windows_desktop/"
    ],
    "tags": [
        "admin-templates",
        "cis",
        "registry",
        "level-2"
    ]
}
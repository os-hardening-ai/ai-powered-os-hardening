{
    "rule_id": "18.9.7.1.3",
    "title": "Ensure 'Also apply to matching devices that are already installed.' is set to 'True'",
    "description": "This policy setting configures an Administrative Template under the System section.",
    "cis_level": 1,
    "category": "Administrative Templates (System)",
    "applies_to": [
        "Windows 11",
        "Windows 10",
        "Windows Server 2022",
        "Windows Server 2019"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SOFTWARE\\\\Policies\\\\Microsoft\\\\Windows\\\\DeviceInstall\\\\Restrictions",
        "value_name": "DenyDeviceClassesRetroactive",
        "value_type": "REG_DWORD",
        "value_data": 1,
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\System",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "System"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeviceInstall\\Restrictions')) { New-Item -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeviceInstall\\Restrictions' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeviceInstall\\Restrictions' -Name 'DenyDeviceClassesRetroactive' -Value 1 -Type DWord -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeviceInstall\\Restrictions\\DenyDeviceClassesRetroactive",
        "inf_value": "4,1",
        "gpo_xml": "<RegistryValue name='DenyDeviceClassesRetroactive' type='REG_DWORD' value='1'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeviceInstall\\Restrictions' -Name 'DenyDeviceClassesRetroactive' -ErrorAction SilentlyContinue).'DenyDeviceClassesRetroactive'; return ($val -eq 1)",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeviceInstall\\Restrictions' -Name 'DenyDeviceClassesRetroactive' -Force"
    },
    "impact": {
        "severity": "medium",
        "description": "Changing system template settings can restrict component usage. Test before deploying."
    },
    "rationale": "Enforcing these configurations aligns with CIS benchmark recommendations.",
    "default_value": {
        "standalone": "Not Configured",
        "domain_joined": "Not Configured"
    },
    "references": [
        "https://www.cisecurity.org/benchmark/microsoft_windows_desktop/"
    ],
    "tags": [
        "admin-templates",
        "cis",
        "registry",
        "system",
        "level-1"
    ]
}
    "description": "CIS automated configuration mapping for 18.10.59.4",
    "cis_level": "1",
    "category": "Administrative Templates: Windows Components",
    "applies_to": [
        "Windows 11"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SOFTWARE\\\\Policies\\\\Microsoft\\\\Windows\\\\Windows Search",
        "value_name": "AllowCortanaAboveLock",
        "value_type": "REG_DWORD",
        "value_data": 0,
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\...",
        "setting_name": "",
        "setting_value": "",

{
    "rule_id": "18.10.17.1",
    "title": "Ensure 'Download Mode' is NOT set to 'Enabled: Internet'",
    "description": "Automated configuration for 18.10.17.1",
    "cis_level": 1,
    "category": "Administrative Templates: Windows Components",
    "applies_to": [
        "Windows 11",
        "Windows 10",
        "Windows Server 2022"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SOFTWARE\\\\Policies\\\\Microsoft\\\\Windows\\\\AppInstaller",
        "value_name": "EnableAppInstaller",
        "value_type": "REG_DWORD",
        "value_data": 0,
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\...",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "System"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\AppInstaller')) { New-Item -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\AppInstaller' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\AppInstaller' -Name 'EnableAppInstaller' -Value 0 -Type DWORD -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\AppInstaller\\EnableAppInstaller",
        "inf_value": "4,1",
        "gpo_xml": "<RegistryValue name='EnableAppInstaller' type='REG_DWORD' value='0'/>"
    },
    "audit_logic": {
        "powershell_script": "$val = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\AppInstaller' -Name 'EnableAppInstaller' -ErrorAction SilentlyContinue).'EnableAppInstaller'; return ($val -eq 0)",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\AppInstaller' -Name 'EnableAppInstaller' -Force"
    },
    "tags": [
        "admin-templates",
        "cis",
        "registry",
        "automated"
    ]
}
{
    "rule_id": "18.6.14.1",
    "title": "Ensure 'Hardened UNC Paths' is set to 'Enabled' for NETLOGON and SYSVOL",
    "description": "This policy setting configures an Administrative Template or MSS Legacy registry key under the Network section.",
    "cis_level": 1,
    "category": "Administrative Templates (Network)",
    "applies_to": [
        "Windows 11",
        "Windows 10",
        "Windows Server 2022",
        "Windows Server 2019",
        "Windows Server 2016"
    ],
    "automated": true,
    "registry_config": {
        "path": "HKLM:\\\\SOFTWARE\\\\Policies\\\\Microsoft\\\\Windows\\\\NetworkProvider\\\\HardenedPaths",
        "value_name": "\\\\*\\NETLOGON",
        "value_type": "REG_SZ",
        "value_data": "RequireMutualAuthentication=1,RequireIntegrity=1,RequirePrivacy=1",
        "comparison": "equals"
    },
    "gpo_config": {
        "policy_path": "Computer Configuration\\Policies\\Administrative Templates\\Network",
        "setting_name": "",
        "setting_value": "",
        "admx_category": "Network"
    },
    "implementation_local": {
        "powershell_command": "",
        "powershell_script": "if (-not (Test-Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\NetworkProvider\\HardenedPaths')) { New-Item -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\NetworkProvider\\HardenedPaths' -Force -ErrorAction SilentlyContinue }; Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\NetworkProvider\\HardenedPaths' -Name '\\\\*\\NETLOGON' -Value 'RequireMutualAuthentication=1,RequireIntegrity=1,RequirePrivacy=1' -Type String -Force; Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\NetworkProvider\\HardenedPaths' -Name '\\\\*\\SYSVOL' -Value 'RequireMutualAuthentication=1,RequireIntegrity=1,RequirePrivacy=1' -Type String -Force",
        "requires_admin": true,
        "requires_reboot": false
    },
    "implementation_gpo": {
        "inf_section": "[Registry Values]",
        "inf_key": "MACHINE\\SOFTWARE\\Policies\\Microsoft\\Windows\\NetworkProvider\\HardenedPaths\\\\\\*\\NETLOGON",
        "inf_value": "1,RequireMutualAuthentication=1,RequireIntegrity=1,RequirePrivacy=1",
        "gpo_xml": "<RegistryValue name='\\\\*\\NETLOGON' type='REG_SZ' value='RequireMutualAuthentication=1,RequireIntegrity=1,RequirePrivacy=1'/><RegistryValue name='\\\\*\\SYSVOL' type='REG_SZ' value='RequireMutualAuthentication=1,RequireIntegrity=1,RequirePrivacy=1'/>"
    },
    "audit_logic": {
        "powershell_script": "$netlogon = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\NetworkProvider\\HardenedPaths' -Name '\\\\*\\NETLOGON' -ErrorAction SilentlyContinue).'\\\\*\\NETLOGON'; $sysvol = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\NetworkProvider\\HardenedPaths' -Name '\\\\*\\SYSVOL' -ErrorAction SilentlyContinue).'\\\\*\\SYSVOL'; return ($netlogon -eq 'RequireMutualAuthentication=1,RequireIntegrity=1,RequirePrivacy=1' -and $sysvol -eq 'RequireMutualAuthentication=1,RequireIntegrity=1,RequirePrivacy=1')",
        "expected_result": true
    },
    "remediation_rollback": {
        "powershell_command": "Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\NetworkProvider\\HardenedPaths' -Name '\\\\*\\NETLOGON' -Force"
    },
    "impact": {
        "severity": "medium",
        "description": "Changing network settings can restrict network protocol usage or legacy features. Test before deploying."
    },
    "rationale": "Enforcing these network configurations aligns with CIS benchmark recommendations.",
    "default_value": {
        "standalone": "Not Configured",
        "domain_joined": "Not Configured"
    },
    "references": [
        "https://www.cisecurity.org/benchmark/microsoft_windows_desktop/"
    ],
    "tags": [
        "admin-templates",
        "network",
        "cis",
        "registry",
        "level-1"
    ]
}
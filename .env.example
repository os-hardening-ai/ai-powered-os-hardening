# ===================================
# LLM Provider Configuration
# ===================================
# Choose one: novita, groq (FREE), ollama (FREE Local), huggingface, openai (PAID)
LLM_PROVIDER=novita


# ===================================
# OpenAI API Configuration (💰 PAID - Not recommended for demo)
# ===================================
# Get API key from: https://platform.openai.com/api-keys
# Cost: ~$0.50-2.00 per 1000 requests
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_SMALL_MODEL_NAME=gpt-4o-mini
OPENAI_LARGE_MODEL_NAME=gpt-4o


# ===================================
# Groq API Configuration (🎁 100% FREE - RECOMMENDED)
# ===================================
# Get FREE API key from: https://console.groq.com/keys
# Free tier: 30 req/min, 14400 req/day
# Speed: 500+ tokens/sec (fastest LLM API)
# Cost: $0 (completely free)
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_SMALL_MODEL_NAME=llama-3.1-8b-instant
GROQ_LARGE_MODEL_NAME=llama-3.3-70b-versatile


# ===================================
# Ollama Configuration (🎁 100% FREE - OFFLINE)
# ===================================
# Install: https://ollama.ai/download
# No API key needed, runs locally
# Run: ollama pull llama3.1:8b && ollama pull llama3.1:70b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_SMALL_MODEL_NAME=llama3.1:8b
OLLAMA_LARGE_MODEL_NAME=llama3.1:70b


# ===================================
# HuggingFace API Configuration
# ===================================
# Get API key from: https://huggingface.co/settings/tokens
HF_API_KEY=hf_your-huggingface-token-here
SMALL_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2
LARGE_MODEL_NAME=mistralai/Mixtral-8x7B-Instruct-v0.1


# ===================================
# Additional API Keys
# ===================================
COHERE_API_KEY=your-cohere-api-key-here
NOVITA_API_KEY=your-novita-api-key-here
QDRANT_API_KEY=your-qdrant-api-key-here

# ===================================
# Qdrant Vector Store
# ===================================
# Qdrant Cloud URL — config.json["vector_store"]["qdrant"]["url"] ile de ayarlanabilir
QDRANT_URL=https://your-cluster-id.cloud.qdrant.io


# ===================================
# Novita LLM Configuration
# ===================================
# LLM_PROVIDER=novita olarak ayarlandığında kullanılır
# Model adları: https://novita.ai/llm-api
NOVITA_SMALL_MODEL_NAME=qwen/qwen3.5-35b-a3b
NOVITA_LARGE_MODEL_NAME=qwen/qwen3.5-122b-a10b


# ===================================
# LANE-TABANLI YÜK DENGELEME (round-robin + fallback)  [opsiyonel]
# ===================================
# Cerebras gpt-oss-120b free tier = 5 istek/dk → tek chat isteği (çok-call) bile limiti
# patlatıyor. Çözüm: birden çok (provider:model) LANE arasında round-robin → her lane'in
# AYRI rate-limit'i → agregat throughput ~lane sayısı katı. small/large havuzları AYRI:
# helper burst (safety/queryplanner/verify) ucuz-hızlı modellere, üretim güçlü modellere.
# Format: "provider:model,provider:model" (provider PROVIDER_PRESETS'te olmalı + key'i .env'de).
# Boşsa → klasik sağlayıcı-zinciri (LLM_PROVIDER) kullanılır.
#
# CEREBRAS_API_KEY / SAMBANOVA_API_KEY / OPENROUTER_API_KEY gereklidir (kullanılan lane'ler için).
# LLM_SMALL_LANES=openrouter:meta-llama/llama-3.2-1b-instruct,openrouter:liquid/lfm-2-24b-a2b,openrouter:mistralai/codestral-2508,openrouter:amazon/nova-micro-v1,sambanova:gemma-3-12b-it
# LLM_LARGE_LANES=cerebras:gpt-oss-120b,openrouter:deepseek/deepseek-v4-flash,sambanova:gemma-3-12b-it
#
# CHAIN_LLM_TIMEOUT=30   # lane başına timeout (s); yavaş lane bu sürede iptal → sıradakine
# LLM_BALANCE_TOP_N=3    # klasik zincirde round-robin yapılacak baş sağlayıcı sayısı (1=kapalı)


# ===================================
# Model Sampling Parameters
# ===================================
# Temperature: 0.0 (deterministic) to 2.0 (creative)
# Small model: Used for classification tasks (lower temp)
# Large model: Used for answer generation (moderate temp)
SMALL_MODEL_TEMPERATURE=0.3
LARGE_MODEL_TEMPERATURE=0.2

# Max tokens per response
MAX_TOKENS=2048


# ===================================
# Pipeline Behavior
# ===================================
# Enable detailed debug logs (true/false)
ENABLE_DEBUG_LOGS=false

# Enable output quality checking (true/false)
ENABLE_JUDGE_STEP=true

# Enable answer correction if judge detects issues (true/false)
ENABLE_CORRECTION_STEP=true


# ===================================
# Advanced Settings
# ===================================
# API request timeout in seconds
REQUEST_TIMEOUT=60

# Number of retry attempts on API failures
MAX_RETRIES=2


# ===================================
# Development Settings (Optional)
# ===================================
# Environment: dev, staging, prod
# ENVIRONMENT=dev

# Log file path
# LOG_FILE=logs/chatbot.log

# Session storage (future: redis, postgres)
# SESSION_STORAGE=memory

# ===================================
# Redis Configuration
# ===================================
# Docker Compose: service adı "redis" — otomatik set edilir (environment: üzerinden)
# Manuel çalıştırma: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Embedding cache TTL (saniye) — default 24 saat
EMBEDDING_CACHE_TTL=86400

# Session store TTL (saniye) — default 1 saat
# Redis kullanılabilirse konuşma geçmişi bu süre saklanır
SESSION_TTL=3600

# ============================================================
# Auth / Security (JWT + RBAC + Audit)
# ============================================================
# JWT imzalama secret'i. AYARLI DEGILSE -> DEV MODE: sabit dev-secret + 4 demo hesap
# (admin/sec/dev/user, parola AUTH_DEMO_PASSWORD veya 'changeme123') seed'lenir.
# Production'da MUTLAKA ayarlayin (>=32 karakter). Uretmek icin:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Access token gecerlilik suresi (dakika) — default 60
JWT_EXPIRY_MINUTES=60

# Prod ilk acilista 'users' tablosu bossa olusturulacak admin parolasi.
# Bossa rastgele uretilir ve baslangicta bir kez konsola yazdirilir.
AUTH_ADMIN_PASSWORD=

# Dev demo hesaplarinin ortak parolasi (yalniz JWT_SECRET boşken).
AUTH_DEMO_PASSWORD=changeme123


# ============================================================
# Deployment (birleşik VPS — docker-compose.prod.yml + Caddy)
# ============================================================
# Bu değişkenler YALNIZ prod override ile birlikte deploy ederken gereklidir
# (docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d).
# Lokal/dev'de boş bırakılabilir.
#
# Distributed tracing — backend OTLP trace'lerini monitoring repo'daki Jaeger'a yollar
# (iç ağ: jaeger:4317). Ayarlı değilse tracing devre dışı (uygulama yine çalışır).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_SERVICE_NAME=hardening-api
#
# TrustedHostMiddleware — izin verilen Host başlıkları (virgülle). Caddy→frontend→api
# zincirinde api 'api' adıyla çağrılır; public host frontend domain'idir.
# ALLOWED_HOSTS=app.hardeningai.site,api,localhost,127.0.0.1
#
# CORS — frontend same-origin proxy kullandığından genelde gerekmez; ayrı origin
# kullanılıyorsa açık origin listesi verin (asla prod'da '*' kullanmayın).
# CORS_ALLOW_ORIGINS=https://app.hardeningai.site
